<clickhouse>
  <default_profile>default</default_profile>
  <profiles>
    <default>
      <join_use_nulls>1</join_use_nulls>
      <distributed_product_mode>global</distributed_product_mode>
    </default>
  </profiles>
  <users>
    <cluster_user>
      <password>cluster_pass</password>
      <networks>
        <ip>::/0</ip>
      </networks>
      <profile>default</profile>
      <quota>default</quota>
    </cluster_user>
    <defaultuser>
      <password>passphrase</password>
      <networks>
        <ip>::/0</ip>
      </networks>
      <profile>default</profile>
      <quota>default</quota>
    </defaultuser>
  </users>
</clickhouse>
